# ── Database (same Postgres DB as hacofood) ───────────────────────────────────
DATABASE_URL=postgres://user:password@host:5432/dbname

# ── Sepay payment gateway ─────────────────────────────────────────────────────
# Lấy từ Sepay dashboard › Cài đặt › Tài khoản ngân hàng
SEPAY_BANK_ACCOUNT=your_bank_account_number
SEPAY_BANK_CODE=MB
SEPAY_ACCOUNT_NAME=BEP CO HA
# API Key để xác thực webhook từ Sepay
SEPAY_API_KEY=your_sepay_api_key

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=Bếp Cô Hạ <no-reply@hacofood.vn>

# ── Telegram notifications ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
# Chat ID của nhóm admin nhận thông báo đơn đăng ký & thanh toán
TELEGRAM_COURSE_GROUP_ID=-100xxxxxxxxxx

# ── Link nhóm học viên kín ───────────────────────────────────────────────────
# Dùng server-side (email gửi sau khi TT), không lộ ra browser
COURSE_GROUP_LINK=https://www.facebook.com/groups/your-group-id
